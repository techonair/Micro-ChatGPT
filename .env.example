APP_NAME=ai-chatbot-backend
ENVIRONMENT=dev
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chatbot

OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
LLAMA_API_BASE_URL=
LLAMA_API_KEY=

OPENAI_CONTEXT_LIMIT=12000
ANTHROPIC_CONTEXT_LIMIT=180000
LLAMA_CONTEXT_LIMIT=8000

SQL_POOL_SIZE=10
SQL_MAX_OVERFLOW=20
SQL_POOL_TIMEOUT=30
SQL_POOL_RECYCLE=1800

LOG_LEVEL=INFO

  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 409', function () {",
                  "  pm.expect([200, 409]).to.include(pm.response.code);",
                  "});",
                  "",
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "",
                  "if (data && data.success && data.data && data.data.user) {",
                  "  pm.collectionVariables.set('userId', data.data.user.id);",
                  "  pm.collectionVariables.set('accessToken', data.data.access_token || '');",
                  "}",
                  "",
                  "if (pm.response.code === 409) {",
                  "  console.log('User already exists. Run Login next.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"full_name\": \"{{fullName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "auth",
                "signup"
              ]
            },
            "description": "Create a user account."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', data.data.access_token || '');",
                  "pm.collectionVariables.set('userId', data.data.user.id || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "auth",
                "login"
              ]
            },
            "description": "Login and capture userId/accessToken in collection variables."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Conversations",
      "item": [
        {
          "name": "Create Conversation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "const id = data?.data?.conversation_id || '';",
                  "pm.collectionVariables.set('conversationId', id);",
                  "pm.collectionVariables.set('sessionId', data?.data?.first_message?.session_id || id);",
                  "pm.test('Conversation id captured', function () {",
                  "  pm.expect(id).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"message\": \"{{conversationStartMessage}}\",\n  \"provider\": \"{{provider}}\",\n  \"model\": \"{{model}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/conversations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "conversations"
              ]
            },
            "description": "Start new conversation with first message."
          },
          "response": []
        },
        {
          "name": "List Conversations",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Has conversations array', function () {",
                  "  pm.expect(data?.data?.conversations).to.be.an('array');",
                  "});",
                  "const first = data?.data?.conversations?.[0];",
                  "if (first && first.conversation_id) {",
                  "  pm.collectionVariables.set('conversationId', first.conversation_id);",
                  "  pm.collectionVariables.set('sessionId', first.conversation_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/conversations?user_id={{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "conversations"
              ],
              "query": [
                {
                  "key": "user_id",
                  "value": "{{userId}}"
                }
              ]
            },
            "description": "Get all conversations for a user."
          },
          "response": []
        },
        {
          "name": "Get Conversation Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Has turns array', function () {",
                  "  pm.expect(data?.data?.turns).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/conversations/{{conversationId}}?user_id={{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "conversations",
                "{{conversationId}}"
              ],
              "query": [
                {
                  "key": "user_id",
                  "value": "{{userId}}"
                }
              ]
            },
            "description": "Get full conversation history by conversation id."
          },
          "response": []
        },
        {
          "name": "Add Message To Conversation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Session id matches conversation', function () {",
                  "  pm.expect(data?.data?.session_id).to.eql(pm.collectionVariables.get('conversationId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"message\": \"{{conversationFollowupMessage}}\",\n  \"provider\": \"{{provider}}\",\n  \"model\": \"{{model}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/conversations/{{conversationId}}/messages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "conversations",
                "{{conversationId}}",
                "messages"
              ]
            },
            "description": "Add a new message to an existing conversation."
          },
          "response": []
        },
        {
          "name": "Delete Conversation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test('Deleted flag is true', function () {",
                  "  pm.expect(data?.data?.deleted).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/conversations/{{conversationId}}?user_id={{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "conversations",
                "{{conversationId}}"
              ],
              "query": [
                {
                  "key": "user_id",
                  "value": "{{userId}}"
                }
              ]
            },
            "description": "Delete a conversation and all messages/summaries."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Send Message (Legacy /chat)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.session_id) {",
                  "  pm.collectionVariables.set('sessionId', data.data.session_id);",
                  "  pm.collectionVariables.set('conversationId', data.data.session_id);",
                  "}",
                  "pm.test('Has assistant response', function () {",
                  "  pm.expect(data.data.output_text).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"message\": \"{{chatMessage}}\",\n  \"session_id\": \"{{sessionId}}\",\n  \"provider\": \"{{provider}}\",\n  \"model\": \"{{model}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/chat",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "chat"
              ]
            },
            "description": "Legacy chat endpoint. If sessionId is empty, server creates one and this request stores it."
          },
          "response": []
        }
      ]
    },

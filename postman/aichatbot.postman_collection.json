{
  "info": {
    "name": "AI Chatbot Backend API",
    "description": "Postman collection for the simplified FastAPI chatbot backend with conversation lifecycle endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "e5d87a1c-4e7c-4e92-a53c-2fc073b4520a"
